# Server
NODE_ENV=development
PORT=3000
# Optional path prefix for all routes, e.g. /zalo
BASE_PATH=

# Zalo Bot (required)
ZALO_TOKEN=your-zalo-bot-token
# Public HTTPS URL that Zalo will call, e.g. https://your-domain.com/api/zalo/webhook
ZALO_WEBHOOK_URL=
# Shared secret sent by Zalo in the x-bot-api-secret-token header
ZALO_SECRET_TOKEN=
# Set to true to use polling instead of webhook (useful for local dev)
ZALO_POLLING=false

# CORS - comma-separated list of allowed origins (empty = allow all)
ALLOWED_ORIGINS=

# Business logic: forward incoming user messages to this endpoint (empty = echo mode)
FORWARD_API_URL=
# Optional Bearer token sent in the Authorization header
FORWARD_API_KEY=
# Request timeout in milliseconds
FORWARD_TIMEOUT_MS=10000
